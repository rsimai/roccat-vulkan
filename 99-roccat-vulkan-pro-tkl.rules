# udev rules for ROCCAT Vulkan Pro TKL (VID 1e7d / PID 311a)
#
# Grants access only to the user at the local physical seat (seat0).
# Users connected via SSH or other non-seat sessions are NOT granted access.
# The ACL is removed automatically when the local user logs out.
#
# TAG+="uaccess" registers the device with systemd-logind for session tracking.
# RUN{builtin}+="uaccess" applies the ACL immediately and synchronously at plug
# time, eliminating the race condition where permissions are lost after replug.
#
# No group membership changes are needed.
#
# Install:
#   sudo cp 99-roccat-vulkan-pro-tkl.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   Then unplug and replug the keyboard.
#
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1e7d", ATTRS{idProduct}=="311a", TAG+="uaccess", RUN{builtin}+="uaccess"
